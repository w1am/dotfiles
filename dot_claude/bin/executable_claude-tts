#!/usr/bin/env bash
set -uo pipefail

PATH="$HOME/.local/bin:$PATH"
export PATH
export PYTHONPATH="$HOME/.claude${PYTHONPATH:+:$PYTHONPATH}"

VENV="$HOME/.claude/tts-venv/bin/python"
PYTHON="${CC_TTS_PYTHON:-$([ -x "$VENV" ] && echo "$VENV" || command -v python3)}"

[ -n "$PYTHON" ] || { echo "no python interpreter found" >&2; exit 1; }

exec "$PYTHON" -m tts "$@"
