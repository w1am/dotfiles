#!/bin/sh
set -eu

# Brewfile hash: {{ include "dot_Brewfile" | sha256sum }}

[ "$(uname -s)" = "Darwin" ] || { echo "not macOS — skipping brew bundle"; exit 0; }
command -v brew >/dev/null 2>&1 || { echo "Homebrew not found — install from https://brew.sh, then re-apply; skipping"; exit 0; }

brew bundle --global
echo "brew bundle complete"
