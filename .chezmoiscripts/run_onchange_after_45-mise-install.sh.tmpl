#!/bin/sh
set -eu

# mise config hash: {{ include "private_dot_config/mise/config.toml" | sha256sum }}

mise="$HOME/.local/bin/mise"
if [ ! -x "$mise" ]; then
    if command -v mise >/dev/null 2>&1; then
        mise="$(command -v mise)"
    else
        echo "mise binary not found (install-mise step should have run first) — skipping tool install"
        exit 0
    fi
fi

echo "Installing mise-managed tools (this can take a while on first run)..."
"$mise" install
"$mise" ls --installed
