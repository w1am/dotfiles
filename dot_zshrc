export PATH="$HOME/.local/bin:$PATH"

if command -v tmux >/dev/null 2>&1 && [[ -o interactive ]] \
    && [[ -z "$TMUX" ]] && [[ "$TERM_PROGRAM" != "vscode" ]]; then
    exec tmux new-session -A -s main
fi

export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

COMPLETION_WAITING_DOTS="true"

unsetopt BEEP
unsetopt LIST_BEEP
unsetopt HIST_BEEP

plugins=(
  git
  sudo
  command-not-found
  colored-man-pages
  zsh-completions
  zsh-autosuggestions
  zsh-syntax-highlighting
  history-substring-search
)

# zsh-completions needs its fpath added before OMZ runs compinit
fpath+=${ZSH}/custom/plugins/zsh-completions/src

source "$ZSH/oh-my-zsh.sh"

HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt EXTENDED_HISTORY

alias ll='ls -lah'
alias ..='cd ..'
alias ...='cd ../..'
alias e='exit'
alias cls='clear'

update() {
  chezmoi git -- add -A &&
  chezmoi git -- status --short &&
  chezmoi git -- commit -m "${*:-update dotfiles}" &&
  chezmoi git -- push
}

command -v fnm >/dev/null 2>&1 && eval "$(fnm env --use-on-cd)"

_auto_venv() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.venv/bin/activate" ]]; then
      [[ "$VIRTUAL_ENV" != "$dir/.venv" ]] && source "$dir/.venv/bin/activate"
      return
    fi
    dir="${dir:h}"
  done
  [[ -n "$VIRTUAL_ENV" ]] && command -v deactivate >/dev/null 2>&1 && deactivate
}
autoload -Uz add-zsh-hook
add-zsh-hook chpwd _auto_venv
_auto_venv

export BUN_INSTALL="$HOME/.bun"
[ -d "$BUN_INSTALL/bin" ] && export PATH="$BUN_INSTALL/bin:$PATH"

export DOTNET_ROOT="$HOME/.dotnet"
if [ -d "$DOTNET_ROOT" ]; then
  export PATH="$DOTNET_ROOT:$DOTNET_ROOT/tools:$PATH"
fi

command -v fdfind >/dev/null 2>&1 && alias fd='fdfind'
command -v batcat >/dev/null 2>&1 && alias bat='batcat'

command -v fzf >/dev/null 2>&1 && source <(fzf --zsh) 2>/dev/null

[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
